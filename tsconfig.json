{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "rewriteRelativeImportExtensions": true,

    "removeComments": true,
    "emitDecoratorMetadata": false,
    //"preserveConstEnums": false,
    "verbatimModuleSyntax": true,
    "noEmitOnError": true,
    "declaration": true,
    "stripInternal": true  // use /** @internal */
  },
  "include": ["src/**/*"]
}
